<Window x:Class="RTSP_Cams2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        mc:Ignorable="d"
        Title="IT TOP GLAZ"
        Width="900"
        Height="600"
        WindowStartupLocation="CenterScreen"
        Background="#111111">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Cameras}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="{Binding GridColumns}" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="1"
                                Background="#1E1E1E"
                                CornerRadius="6"
                                BorderBrush="#333333"
                                BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <vlc:VideoView Grid.Row="0"
                                               MediaPlayer="{Binding MediaPlayer}" />

                                <DockPanel Grid.Row="1" Margin="1">
                                    <TextBlock Text="{Binding Title}"
                                               Foreground="White"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />

                                    <TextBlock Text="{Binding Status}"
                                               Foreground="#BBBBBB"
                                               Margin="12,0,0,0"
                                               VerticalAlignment="Center" />

                                    <Button Content="⛶"
                                            Width="28"
                                            Height="22"
                                            Margin="8,0,0,0"
                                            HorizontalAlignment="Right"
                                            DockPanel.Dock="Right"
                                            Click="FullscreenButton_Click"
                                            Tag="{Binding}" />
                                </DockPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border x:Name="ShowSettingsBorder"
                Visibility="Visible"
                Grid.Row="1"
                Background="#1A1A1A"
                BorderBrush="#333333"
                BorderThickness="1,1,1,0"
                Padding="0"
                MouseDown="ShowSettings"
                >
            <TextBlock HorizontalAlignment="Center" Text="▲" Foreground="White" Margin="0,0,8,0" 
                       MouseDown="ShowSettings"/>
        </Border>

        <Border x:Name="SettingsBorder"
                Visibility="Collapsed"
                Grid.Row="2"
                Background="#1A1A1A"
                BorderBrush="#333333"
                BorderThickness="1,1,1,0"
                Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="IP-адрес" Foreground="White" Margin="0,0,8,4" />
                <TextBlock Grid.Row="0" Grid.Column="1" Text="Имя пользователя" Foreground="White" Margin="0,0,8,4" />
                <TextBlock Grid.Row="0" Grid.Column="2" Text="Пароль" Foreground="White" Margin="0,0,8,4" />
                <TextBlock Grid.Row="0" Grid.Column="3" Text="Количество камер" Foreground="White" Margin="0,0,8,4" />

                <TextBox Grid.Row="1"
                         Grid.Column="0"
                         Margin="0,0,8,0"
                         Text="{Binding Settings.IpAddress, UpdateSourceTrigger=PropertyChanged}" />

                <TextBox Grid.Row="1"
                         Grid.Column="1"
                         Margin="0,0,8,0"
                         Text="{Binding Settings.Username, UpdateSourceTrigger=PropertyChanged}" />

                <PasswordBox Grid.Row="1"
                             Grid.Column="2"
                             Margin="0,0,8,0"
                             x:Name="PasswordInput"
                             PasswordChanged="PasswordInput_OnPasswordChanged" />

                <TextBox Grid.Row="1"
                         Grid.Column="3"
                         Margin="0,0,8,0"
                         Text="{Binding Settings.CameraCount, UpdateSourceTrigger=PropertyChanged}" />

                <StackPanel Grid.Row="0"
                            Grid.RowSpan="2"
                            Grid.Column="4"
                            Orientation="Horizontal"
                            VerticalAlignment="Bottom">
                    <Button Content="Сохранить"
                            Width="100"
                            Height="30"
                            Margin="0,0,8,0"
                            Click="SaveButton_Click" />
                    <Button Content="Запустить"
                            Width="100"
                            Height="30"
                            Click="StartButton_Click" />
                </StackPanel>
            </Grid>
        </Border>

        
    </Grid>
</Window>