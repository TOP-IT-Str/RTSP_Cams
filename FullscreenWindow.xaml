<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" x:Class="RTSP_Cams.FullscreenWindow"
        Title="Камера"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        Background="Black"
        Topmost="True"
        KeyDown="Window_KeyDown"
        MouseDown="CloseBtn_OnMouseDown" Width="640" Height="480">
    <Grid Background="Black" >
        <vlc:VideoView x:Name="mainVideoView"
                       Margin="0 30 0 0" />
        <vlc:VideoView x:Name="subVideoView"
                       Margin="0 30 0 0" />

        <Border VerticalAlignment="Top"
                HorizontalAlignment="Right"
                Margin="16 2"
                Padding="10,2"
                Background="#66000000"
                CornerRadius="6">
            <DockPanel>
                <TextBlock
                           Foreground="White"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Text="Громкость" />
                <Slider x:Name="VolumeSlider"
                    Width="100" Height="20"
                    Margin="10, 0"
                    Minimum="0" Maximum="100" Value="0"
                    ValueChanged="VolumeSlider_OnValueChanged"
                />
                <TextBlock x:Name="TextVolumeValue"
                    Foreground="White"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Margin="0, 0, 50, 0"
                    Width="30"
                    TextAlignment="Center"
                    Text="0"/>
                <Button Width="26" Height="26" Content="X" HorizontalAlignment="Center" Margin="0" 
                        VerticalAlignment="Center"
                        Click="ButtonBase_OnClick"></Button>
            </DockPanel>
        </Border>

        <Border VerticalAlignment="Top"
                HorizontalAlignment="Left"
                Margin="16 0"
                Padding="10,2"
                Background="#66000000"
                CornerRadius="6">
            <DockPanel>
                <TextBlock x:Name="TitleText"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Text="Camera" />
                <TextBlock x:Name="StreamTypeText"
                           Foreground="White"
                           Opacity="0.5"
                           Margin="10,4"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Text="substream"/>
            </DockPanel>
        </Border>

        <Border VerticalAlignment="Bottom"
                HorizontalAlignment="Right"
                Margin="16"
                Padding="10,6"
                Background="#66000000"
                CornerRadius="6">
                <TextBlock Foreground="White"
                           FontSize="14"
                           Text="Esc — закрыть" />
        </Border>
    </Grid>
</Window>