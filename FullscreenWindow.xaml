<Window x:Class="RTSP_Cams.FullscreenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        Title="Камера"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        Background="Black"
        Topmost="True"
        KeyDown="Window_KeyDown"
        MouseDown="CloseBtn_OnMouseDown">
    <Grid Background="Black">
        <vlc:VideoView x:Name="mainVideoView"
                       Margin="0 30 0 0" />
        <vlc:VideoView x:Name="subVideoView"
                       Margin="0 30 0 0" />
        
        <Border VerticalAlignment="Top"
                HorizontalAlignment="Right"
                Margin="16 2"
                Padding="10,2"
                Background="#66000000"
                CornerRadius="6">
        <Button Width="26" Height="26" Content="X" HorizontalAlignment="Center" Margin="0" 
                VerticalAlignment="Center" 
                />
        </Border>

        <Border VerticalAlignment="Top"
                HorizontalAlignment="Left"
                Margin="16 0"
                Padding="10,2"
                Background="#66000000"
                CornerRadius="6">
            <DockPanel>
                <TextBlock x:Name="TitleText"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="SemiBold" />
                <TextBlock x:Name="StreamTypeText"
                           Foreground="White"
                           Opacity="0.5"
                           Margin="10,4"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Text="substream"/>
            </DockPanel>
        </Border>

        <Border VerticalAlignment="Bottom"
                HorizontalAlignment="Right"
                Margin="16"
                Padding="10,6"
                Background="#66000000"
                CornerRadius="6">
            <TextBlock Foreground="White"
                       FontSize="14"
                       Text="Esc — закрыть" />
        </Border>
    </Grid>
</Window>